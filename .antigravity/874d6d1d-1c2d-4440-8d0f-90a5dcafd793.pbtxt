        lines {
          text: "    \"\352\271\200\354\210\230\355\230\204 PM: \354\240\204\354\262\264 \354\267\250\355\225\251 \355\233\204 \354\260\250\354\204\270\353\214\200 \354\212\244\353\247\210\355\212\270 \355\230\270\355\205\224 \353\241\234\353\264\207 \352\260\200\354\235\264\353\223\234 \354\265\234\354\242\205 \354\203\201\354\204\270 \352\270\260\353\212\245 \354\240\225\354\235\230\354\204\234(PRD) \353\260\260\355\217\254 \353\260\217 \352\270\260\355\232\215 \354\213\254\354\202\254 \354\212\271\354\235\270 \354\203\201\354\213\240\""
