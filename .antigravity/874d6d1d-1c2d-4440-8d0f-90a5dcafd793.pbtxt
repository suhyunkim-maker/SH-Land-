        lines {
          text: "    \"\353\260\225\354\204\261\354\247\204 \355\205\214\355\201\254\353\246\254\353\223\234: F&B \353\260\260\354\244\200\355\230\270 PM\352\263\274 \355\230\221\354\227\205\355\225\230\354\227\254 \354\213\235\354\235\214\353\243\214 \353\260\234\354\243\274 \355\206\265\354\213\240 \354\235\270\355\204\260\355\216\230\354\235\264\354\212\244 \355\224\204\353\241\234\355\206\240\355\203\200\354\236\205 \354\204\244\352\263\204 \353\260\217 \352\270\260\352\270\260 \355\205\214\354\212\244\355\212\270\353\262\240\353\223\234 \352\260\234\354\204\244 \354\231\204\353\243\214 (\352\270\260\355\225\234: 6\354\233\224 5\354\235\274)\","
