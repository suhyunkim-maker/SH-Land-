          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        return m.date.startsWith(yearMonth);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        const sun = new Date(currentDate);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        sun.setDate(currentDate.getDate() - currentDate.getDay());"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        const sat = new Date(sun);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
