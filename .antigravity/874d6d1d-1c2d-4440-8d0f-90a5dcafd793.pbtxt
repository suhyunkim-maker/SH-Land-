        lines {
          text: "  department: \'\355\230\270\355\205\224 IT \354\202\254\354\227\205\353\266\200\',"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  participants: \'\352\271\200\354\210\230\355\230\204 PM, \353\260\225\354\204\261\354\247\204 \355\205\214\355\201\254\353\246\254\353\223\234, \354\235\264\353\202\230\353\235\274 \354\204\234\353\271\204\354\212\244\355\214\200\354\236\245\',"
