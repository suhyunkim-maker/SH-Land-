    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Meeting } from \'../types\';\nimport { \n  Building2, \n  Trash2, \n  Calendar, \n  Plus, \n  ListMusic, \n  FileCheck, \n  Search,\n  ChevronRight,\n  Sparkles\n} from \'lucide-react\';\n\ninterface SidebarProps {\n  meetings: Meeting[];\n  currentMeetingId: string | null;\n  onSelectMeeting: (id: string) => void;\n  onDeleteMeeting: (id: string, e: React.MouseEvent) => void;\n  onNewMeeting: () => void;\n}\n\nexport default function Sidebar({\n  meetings,\n  currentMeetingId,\n  onSelectMeeting,\n  onDeleteMeeting,\n  onNewMeeting\n}: SidebarProps) {\n  const [searchQuery, setSearchQuery] = useState(\'\');\n\n  const filteredMeetings = meetings.filter(m => \n    m.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\n    m.department.toLowerCase().includes(searchQuery.toLowerCase()) ||\n    m.content.toLowerCase().includes(searchQuery.toLowerCase())\n  );\n\n  return (\n    <aside id=\"sidebar-container\" className=\"w-80 border-r border-[#C5A880]/20 bg-[#0B2240] text-slate-100 flex flex-col h-full shrink-0 select-none\">\n      {/* Brand Header */}\n      <div id=\"brand-header animate-fade-in\" className=\"p-5 border-b border-white/10 flex flex-col gap-2\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"p-2 bg-[#C5A880]/15 rounded-lg border border-[#C5A880]/30 shadow-inner\">\n            <Building2 className=\"h-6 w-6 text-[#C5A880]\" />\n          </div>\n          <div>\n            <h1 className=\"font-display font-bold text-lg tracking-wider text-slate-100 leading-tight\">\n              E-LAND HOTEL\n            </h1>\n            <p className=\"text-[10px] tracking-widest text-[#C5A880] uppercase font-semibold\">\n              IT Meeting Recorder\n            </p>\n          </div>\n        </div>\n        <div className=\"text-[11px] text-slate-400 mt-2 bg-black/25 px-2.5 py-1 rounded border border-white/5 font-mono\">\n          \353\214\200\353\252\250\354\202\260 \355\230\270\355\205\224\354\202\254\354\227\205\353\266\200 IT \354\204\234\353\271\204\354\212\244 \352\270\260\355\232\215\n        </div>\n      </div>\n\n      {/* Action Button */}\n      <div className=\"p-4\">\n        <button\n          id=\"btn-new-meeting\"\n          onClick={onNewMeeting}\n          className=\"w-full flex items-center justify-center gap-2 py-3 px-4 bg-[#C5A880] hover:bg-[#A38258] text-[#0B2240] font-semibold text-sm rounded-lg transition-all shadow-md active:scale-[0.98]\"\n        >\n          <Plus className=\"h-4 w-4\" />\n          <span>\354\203\210 \355\232\214\354\235\230 \354\266\224\352\260\200\355\225\230\352\270\260</span>\n        </button>\n      </div>\n\n      {/* Search Input */}\n      <div className=\"px-4 pb-3\">\n        <div className=\"relative\">\n          <Search className=\"absolute left-3 top-2.5 h-4 w-4 text-slate-400\" />\n          <input\n            id=\"sidebar-search\"\n            type=\"text\"\n            placeholder=\"\355\232\214\354\235\230 \354\240\234\353\252\251, \353\266\200\354\204\234, \353\202\264\354\232\251 \352\262\200\354\203\211...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            className=\"w-full pl-9 pr-3 py-2 bg-white/5 border border-white/10 rounded-lg text-xs placeholder:text-slate-400 focus:outline-none focus:border-[#C5A880] focus:ring-1 focus:ring-[#C5A880] transition-all text-slate-200\"\n          />\n        </div>\n      </div>\n\n      {/* Meeting History List */}\n      <div className=\"flex-1 overflow-y-auto custom-scrollbar px-2 pb-4\">\n        <p className=\"px-3 text-[11px] font-bold text-[#C5A880] uppercase tracking-widest mb-2 font-display\">\n          \355\232\214\354\235\230 \354\235\264\353\240\245 ({filteredMeetings.length})\n        </p>\n\n        {filteredMeetings.length === 0 ? (\n          <div className=\"p-6 text-center text-slate-400\">\n            <p className=\"text-xs\">\354\240\200\354\236\245\353\220\234 \355\232\214\354\235\230 \352\270\260\353\241\235\354\235\264 \354\227\206\354\212\265\353\213\210\353\213\244.</p>\n          </div>\n        ) : (\n          <div className=\"space-y-1.5\">\n            {filteredMeetings.map((meeting) => {\n              const isActive = meeting.id === currentMeetingId;\n              return (\n                <div\n                  key={meeting.id}\n                  id={`meeting-item-${meeting.id}`}\n                  onClick={() => onSelectMeeting(meeting.id)}\n                  className={`group relative p-3.5 rounded-lg cursor-pointer transition-all border ${\n                    isActive\n                      ? \'bg-white/10 border-[#C5A880]/60 shadow-md translate-x-1\'\n                      : \'bg-white/0 border-transparent hover:bg-white/5 hover:border-white/5\'\n                  }`}\n                >\n                  <div className=\"flex justify-between items-start mb-1 pr-6\">\n                    <h3 className=\"font-medium text-[13px] text-slate-100 group-hover:text-[#C5A880] transition-colors line-clamp-1\">\n                      {meeting.title || \'\354\240\234\353\252\251 \354\227\206\353\212\224 \353\257\270\355\214\205\'}\n                    </h3>\n                  </div>\n\n                  <div className=\"flex items-center gap-1.5 text-[11px] text-slate-400\">\n                    <Building2 className=\"h-3 w-3\" />\n                    <span className=\"line-clamp-1\">{meeting.department || \'\353\266\200\354\204\234 \353\271\204\352\263\265\352\260\234\'}</span>\n                  </div>\n\n                  <div className=\"flex items-center justify-between mt-2.5 text-[11px]\">\n                    <div className=\"flex items-center gap-1 text-slate-400\">\n                      <Calendar className=\"h-3 w-3\" />\n                      <span>{meeting.date}</span>\n                    </div>\n\n                    <div className=\"flex items-center gap-1.5\">\n                      {meeting.isAiSummarized && (\n                        <span className=\"flex items-center gap-0.5 px-1.5 py-0.5 bg-[#C5A880]/20 text-[#C5A880] rounded text-[9px] font-semibold border border-[#C5A880]/30\">\n                          <Sparkles className=\"h-2 w-2\" />\n                          AI\n                        </span>\n                      )}\n                      \n                      <button\n                        id={`btn-delete-${meeting.id}`}\n                        onClick={(e) => onDeleteMeeting(meeting.id, e)}\n                        className=\"opacity-0 group-hover:opacity-100 hover:text-red-400 text-slate-400 transition-opacity p-1 hover:bg-slate-800 rounded\"\n                        title=\"\352\270\260\353\241\235 \354\202\255\354\240\234\"\n                      >\n                        <Trash2 className=\"h-3.5 w-3.5\" />\n                      </button>\n                    </div>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        )}\n      </div>\n\n      {/* Footer Info */}\n      <div className=\"p-4 border-t border-white/5 text-[11px] text-slate-400 font-mono text-center bg-black/10\">\n        E-Land System Environment\n      </div>\n    </aside>\n  );\n}\n"
    }
