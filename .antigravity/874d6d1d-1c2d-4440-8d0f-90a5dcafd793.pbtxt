        lines {
          text: "\352\271\200\354\210\230\355\230\204 PM: \354\240\200\353\262\210 \354\243\274\354\227\220 \353\260\260\355\217\254\355\226\210\353\215\230 \352\263\240\352\260\235 \352\260\235\354\213\244 \352\260\200\354\235\264\353\223\234 \353\241\234\353\264\207 \354\213\234\353\262\224 \354\204\234\353\271\204\354\212\244 \353\260\230\354\235\221\354\235\264 \353\247\244\354\232\260 \353\234\250\352\262\201\354\212\265\353\213\210\353\213\244. 20\353\214\200\354\231\200 30\353\214\200 \353\271\204\354\246\210\353\213\210\354\212\244 \355\210\254\354\210\231\352\260\235\353\223\244 \354\202\254\354\235\264\354\227\220\354\204\234 \353\247\214\354\241\261\353\217\204 \354\241\260\354\202\254\352\260\200 92%\353\245\274 \353\213\254\354\204\261\355\226\210\353\204\244\354\232\224. \354\235\264\353\262\210 \355\232\214\354\235\230\353\245\274 \355\206\265\355\225\264\354\204\234 \353\213\244\354\235\214 \353\213\250\352\263\204\354\235\270 \'\354\212\244\353\247\210\355\212\270 \354\230\244\353\215\224 \354\227\260\353\217\231 \354\227\260\354\202\260 \354\204\234\353\271\204\354\212\244\' \352\263\274\354\240\234\354\235\230 \353\247\210\354\235\274\354\212\244\355\206\244\352\263\274 \354\227\205\353\254\264 \355\225\240\353\213\271\354\235\204 \354\240\225\353\246\254\355\225\230\352\262\240\354\212\265\353\213\210\353\213\244. "
