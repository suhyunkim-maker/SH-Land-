      replacement_content: "  // 4. Create new meeting structure\n  const handleNewMeeting = (presetDate?: string) => {\n    if (recordingStatus === \'listening\') {\n      alert(\"\353\214\200\355\231\224 \354\210\230\354\247\221 \354\262\230\353\246\254 \354\244\221\354\227\220\353\212\224 \354\203\210 \353\257\270\355\214\205\354\235\204 \352\260\234\354\204\244\355\225\240 \354\210\230 \354\227\206\354\212\265\353\213\210\353\213\244. \353\250\274\354\240\200 \352\270\260\353\241\235 \354\240\225\354\247\200(Stop)\353\245\274 \355\225\264 \354\243\274\354\204\270\354\232\224.\");\n      return;\n    }\n\n    const defaultDate = presetDate || new Date().toISOString().slice(0, 10);\n    // Extract MM/DD format\n    const formattedTitleSuffix = defaultDate.slice(5).replace(\'-\', \'/\');\n\n    const newM: Meeting = {\n      id: \'meeting-\' + Date.now(),\n      title: \'\354\203\210\353\241\234\354\232\264 \355\230\270\355\205\224 IT \352\270\260\355\232\215 \353\257\270\355\214\205 \' + formattedTitleSuffix,\n      department: \'\355\230\270\355\205\224 IT \354\202\254\354\227\205\353\266\200\',\n      participants: \'\',\n      date: defaultDate,\n      content: \'\',\n      summary: \'\',\n      actionItems: [],\n      isAiSummarized: false,\n      createdAt: new Date().toISOString()\n    };"
