        }
        lines {
          text: "### 2. \355\226\245\355\233\204 \354\266\224\354\247\204 \353\260\251\355\226\245 (\355\224\204\353\241\234\354\240\235\355\212\270 \353\247\210\354\235\274\354\212\244\355\206\244)"
