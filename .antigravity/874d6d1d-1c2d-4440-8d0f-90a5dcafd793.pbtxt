      replacement_content: "const LOCAL_STORAGE_KEY = \'sh-hotel-meetings\';\n\n// High-fidelity pre-populated SH default meeting to make the UI look stunning and complete on first load\nconst DEFAULT_MEETING: Meeting = {\n  id: \'sh-sample-1\',\n  title: \'\353\214\200\353\252\250\354\202\260 SH\355\230\270\355\205\224 \353\241\234\353\264\207 \354\236\220\353\217\231\355\231\224 \354\204\234\353\271\204\354\212\244 \354\204\244\352\263\204 \354\243\274\352\260\204 \353\257\270\355\214\205\',\n  department: \'\355\230\270\355\205\224 IT \354\202\254\354\227\205\353\266\200\',\n  participants: \'\352\271\200\354\210\230\355\230\204 PM, \353\260\225\354\204\261\354\247\204 \355\205\214\355\201\254\353\246\254\353\223\234, \354\235\264\353\202\230\353\235\274 \354\204\234\353\271\204\354\212\244\355\214\200\354\236\245\',\n  date: new Date().toISOString().slice(0, 10),\n  content: `\354\230\244\353\212\230 \353\257\270\355\214\205\354\235\204 \352\260\200\354\247\221\353\213\210\353\213\244. \355\232\214\354\235\230 \354\213\234\354\236\221\355\225\230\353\217\204\353\241\235 \355\225\230\352\262\240\354\212\265\353\213\210\353\213\244.\n\352\271\200\354\210\230\355\230\204 PM: \354\240\200\353\262\210 \354\243\274\354\227\220 \353\260\260\355\217\254\355\226\210\353\215\230 \352\263\240\352\260\235 \352\260\235\354\213\244 \352\260\200\354\235\264\353\223\234 \353\241\234\353\264\207 \354\213\234\353\262\224 \354\204\234\353\271\204\354\212\244 \353\260\230\354\235\221\354\235\264 \353\247\244\354\232\260 \353\234\250\352\262\201\354\212\265\353\213\210\353\213\244. 20\353\214\200\354\231\200 30\353\214\200 \353\271\204\354\246\210\353\213\210\354\212\244 \355\210\254\354\210\231\352\260\235\353\223\244 \354\202\254\354\235\264\354\227\220\354\204\234 \353\247\214\354\241\261\353\217\204 \354\241\260\354\202\254\352\260\200 92%\353\245\274 \353\213\254\354\204\261\355\226\210\353\204\244\354\232\224. \354\235\264\353\262\210 \355\232\214\354\235\230\353\245\274 \355\