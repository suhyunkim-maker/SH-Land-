          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        const endOfWeek = formatDateStr(sat);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        return m.date >= startOfWeek && m.date <= endOfWeek;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
