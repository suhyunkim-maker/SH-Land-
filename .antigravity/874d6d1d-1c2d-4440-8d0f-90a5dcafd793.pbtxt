          text: "  - \352\260\200\354\235\264\353\223\234 \353\241\234\353\264\207 \354\213\234\353\262\224 \353\217\204\354\236\205 \355\233\204 \354\213\244\354\213\234\355\225\234 20/30\353\214\200 \353\271\204\354\246\210\353\213\210\354\212\244 \355\210\254\354\210\231\352\260\235 \353\214\200\354\203\201 \353\247\214\354\241\261\353\217\204 \354\241\260\354\202\254 \352\262\260\352\263\274 **92%** \352\263\240\353\223\235\354\240\220 \353\213\254\354\204\261. \354\204\234\353\271\204\354\212\244 \355\232\250\354\232\251\354\204\261 \355\231\225\354\235\270 \354\231\204\353\243\214."
