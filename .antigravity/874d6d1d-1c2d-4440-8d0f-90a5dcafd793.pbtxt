    user_response: "[Situation] \353\202\230\353\212\224 \353\214\200\353\252\250\354\202\260 \355\230\270\355\205\224\354\202\254\354\227\205\353\266\200\354\235\230 IT \354\204\234\353\271\204\354\212\244 \352\270\260\355\232\215 \353\213\264\353\213\271\354\236\220(PM)\354\225\274.\n[Task] Web Speech API\353\245\274 \355\231\234\354\232\251\355\225\230\354\227\254 \353\257\270\355\214\205 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270\353\241\234 \353\263\200\355\231\230(STT)\355\225\230\352\263\240 \354\240\200\354\236\245\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\202\254\353\202\264 \354\233\271 \354\204\234\353\271\204\354\212\244\353\245\274 \352\265\254\354\266\225\355\225\230\353\240\244\352\263\240 \355\225\264. \354\235\264 \354\204\234\353\271\204\354\212\244\353\245\274 AI Studio\353\245\274 \355\206\265\355\225\234 \'\353\260\224\354\235\264\353\270\214 \354\275\224\353\224\251\'\354\234\274\353\241\234 \352\260\234\353\260\234\355\225\230\352\270\260 \354\234\204\355\225\264, \354\231\204\353\262\275\355\225\234 \355\230\225\355\203\234\354\235\230 PRD(\354\240\234\355\222\210 \354\232\224\352\265\254\354\202\254\355\225\255 \354\240\225\354\235\230\354\204\234)\353\245\274 \354\240\234\354\236\221\355\225\264 \354\244\230.\n[Intent] \354\235\264 \355\224\204\353\241\234\354\240\235\355\212\270\353\245\274 \354\247\204\355\226\211\355\225\230\353\212\224 \354\235\264\354\234\240\353\212\224 \353\266\200\354\204\234 \353\202\264 \354\236\246\354\235\200 \353\257\270\355\214\205 \353\202\264\354\232\251\354\235\204 \353\213\250\354\210\234\355\236\210 \353\205\271\354\235\214\355\225\230\353\212\224 \352\262\203\354\235\204 \353\204\230\354\226\264, \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270 \353\215\260\354\235\264\355\204\260\355\231\224\355\225\230\354\227\254 \355\232\214\354\235\230\353\241\235 \354\236\221\354\204\261 \354\213\234\352\260\204\354\235\204 \353\213\250\354\266\225\355\225\230\352\263\240 \355\225\265\354\213\254 \355\232\214\354\235\230 \353\215\260\354\235\264\355\204\260\353\245\274 \354\236\220\354\202\260\355\231\224\355\225\230\354\227\254 \354\227\205\353\254\264 \355\232\250\354\234\250\354\235\204 \353\206\222\354\235\264\352\270\260 \354\234\204\355\225\250\354\235\264\354\225\274.\n\n[Concerns] \n- AI Studio\354\227\220\354\204\234 \354\202\254\354\232\251\355\225\230\353\212\224 React \352\270\260\354\210\240\354\227\220 \353\247\236\352\262\214 \353\247\214\353\223\244\354\226\264\354\240\270\354\225\274 \355\225\251\353\213\210\353\213\244.\n- Web Speech API\354\235\230 \355\212\271\354\204\261(\353\270\214\353\235\274\354\232\260\354\240\200 \355\230\270\355\231\230\354\204\261, \353\260\261\352\267\270\353\235\274\354\232\264\353\223\234 \354\236\221\353\217\231 \355\225\234\352\263\204 \353\223\261)\354\235\204 \352\263\240\353\240\244\355\225\234 \354\230\210\354\231\270 \354\262\230\353\246\254 \353\260\217 UX \352\270\260\355\232\215\354\235\264 \355\217\254\355\225\250\353\220\230\354\227\210\354\234\274\353\251\264 \354\242\213\352\262\240\354\226\264.\n- \354\265\234\354\242\205\354\240\201\354\234\274\353\241\234 \354\236\221\354\204\261\355\225\264 \354\244\204 PRD\353\212\224 \353\202\264\352\260\200 \355\225\234 \353\262\210\354\227\220 \353\263\265\354\202\254\355\225\264\354\204\234 AI Studio\354\227\220 \353\266\231\354\227\254\353\204\243\354\235\204 \354\210\230 \354\236\210\353\217\204\353\241\235 \353\247\210\355\201\254\353\213\244\354\232\264 \355\230\225\354\213\235\354\235\230 \354\275\224\353\223\234 \353\270\224\353\241\235\354\234\274\353\241\234 \352\260\220\354\213\270\354\204\234 \354\266\234\353\240\245\355\225\264 \354\244\230.\n[Calibration] \353\202\264 \354\235\230\353\217\204\353\245\274 \354\240\225\355\231\225\355\236\210 \355\214\214\354\225\205\355\225\230\354\227\254 \354\265\234\354\240\201\354\235\230 PRD\353\245\274 \354\236\221\354\204\261\355\225\230\352\270\260 \354\234\204\355\225\264, \353\263\270\352\262\251\354\240\201\354\235\270 \353\213\265\353\263\200(PRD \354\236\221\354\204\261)\354\235\204 \354\213\234\354\236\221\355\225\230\352\270\260 \354\240\204\354\227\220 \353\202\230\354\227\220\352\262\214 \355\225\204\354\232\224\355\225\234 \354\240\225\353\263\264\353\245\274 3\352\260\200\354\247\200 \354\235\264\354\203\201 \353\213\250\352\263\204\354\240\201\354\234\274\353\241\234 \354\247\210\353\254\270\355\225\264 \354\244\230.# [PRD] \354\213\244\354\213\234\352\260\204 \353\257\270\355\214\205 \354\235\214\354\204\261 \352\270\260\353\241\235 \353\260\217 \352\264\200\353\246\254 \354\204\234\353\271\204\354\212\244 (Chrome \354\240\204\354\232\251)\n\n## 1. \355\224\204\353\241\234\354\240\235\355\212\270 \352\260\234\354\232\224\n- **\355\224\204\353\241\234\354\240\235\355\212\270 \353\252\205**: E-Land Hotel Meeting Recorder (\352\260\200\354\271\255)\n- **\353\252\251\354\240\201**: \353\257\270\355\214\205 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270\353\241\234 \353\263\200\355\231\230(STT)\355\225\230\354\227\254 \355\232\214\354\235\230\353\241\235 \354\236\221\354\204\261 \354\213\234\352\260\204\354\235\204 \353\213\250\354\266\225\355\225\230\352\263\240, \354\202\254\353\202\264 \355\232\214\354\235\230 \353\215\260\354\235\264\355\204\260\353\245\274 \354\236\220\354\202\260\355\231\224\355\225\250.\n- **\354\243\274\354\232\224 \355\203\200\352\262\237**: \354\235\264\353\236\234\353\223\234 \355\230\270\355\205\224\354\202\254\354\227\205\353\266\200 \354\236\204\354\247\201\354\233\220 (Chrome \353\270\214\353\235\274\354\232\260\354\240\200 \354\202\254\354\232\251\354\236\220)\n- **\352\270\260\354\210\240 \354\212\244\355\203\235**: React (Vite), Tailwind CSS, Lucide React (Icons), Web Speech API\n\n## 2. \355\225\265\354\213\254 \352\270\260\353\212\245 \354\232\224\352\265\254\354\202\254\355\225\255\n\n### 2.1. \353\257\270\355\214\205 \353\251\224\355\203\200\353\215\260\354\235\264\355\204\260 \354\236\205\353\240\245 (\354\236\205\353\240\245 \355\217\274)\n- \353\257\270\355\214\205 \354\213\234\354\236\221 \354\240\204, \353\213\244\354\235\214\352\263\274 \352\260\231\354\235\200 \354\240\225\353\263\264\353\245\274 \354\236\205\353\240\245\355\225\240 \354\210\230 \354\236\210\353\212\224 \355\217\274\354\235\204 \354\240\234\352\263\265\355\225\250.\n    - \353\257\270\355\214\205 \354\240\234\353\252\251 (\355\225\204\354\210\230)\n    - \353\266\200\354\204\234\353\252\205 / \354\260\270\354\204\235\354\236\220\n    - \353\202\240\354\247\234 (\352\270\260\353\263\270\352\260\222: \354\230\244\353\212\230)\n\n### 2.2. \354\213\244\354\213\234\352\260\204 STT (Web Speech API \355\231\234\354\232\251)\n- **\354\213\244\354\213\234\352\260\204 \355\205\215\354\212\244\355\212\270 \353\263\200\355\231\230**: \353\247\210\354\235\264\355\201\254 \352\266\214\355\225\234 \354\212\271\354\235\270 \355\233\204, \354\202\254\354\232\251\354\236\220\354\235\230 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\231\224\353\251\264\354\227\220 \354\266\234\353\240\245\355\225\250.\n- **\355\231\225\354\240\225/\353\271\204\355\231\225\354\240\225 \355\205\215\354\212\244\355\212\270 \352\265\254\353\266\204**: \353\263\200\355\231\230 \354\244\221\354\235\270 \353\254\270\354\236\245(Interim)\352\263\274 \353\263\200\355\231\230\354\235\264 \354\231\204\353\243\214\353\220\234 \353\254\270\354\236\245\354\235\204 \354\213\234\352\260\201\354\240\201\354\234\274\353\241\234 \352\265\254\353\266\204\355\225\230\354\227\254 \354\202\254\354\232\251\354\236\220 \352\262\275\355\227\230 \355\226\245\354\203\201.\n- **\354\227\260\354\206\215 \354\235\270\354\213\235 \354\262\230\353\246\254**: Web Speech API\354\235\230 \355\212\271\354\247\225\354\235\270 \'\353\254\264\354\235\214 \354\213\234 \354\236\220\353\217\231 \354\242\205\353\243\214\'\353\245\274 \353\260\251\354\247\200\355\225\230\352\270\260 \354\234\204\355\225\264, \354\235\270\354\213\235\354\235\264 \353\201\212\352\270\270 \352\262\275\354\232\260 \354\236\220\353\217\231\354\234\274\353\241\234 \353\213\244\354\213\234 \354\213\234\354\236\221\355\225\230\353\212\224 \353\241\234\354\247\201 \355\217\254\355\225\250.\n\n### 2.3. \352\270\260\353\241\235 \355\216\270\354\247\221 \353\260\217 \354\240\200\354\236\245\n- **\354\210\230\354\240\225 \353\252\250\353\223\234**: \352\270\260\353\241\235\354\235\264 \354\231\204\353\243\214\353\220\234 \355\233\204(Stop), \354\203\235\354\204\261\353\220\234 \355\205\215\354\212\244\355\212\270 \354\240\204\354\262\264\353\245\274 \354\236\220\354\234\240\353\241\255\352\262\214 \354\210\230\354\240\225\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\227\220\353\224\224\355\204\260 \353\252\250\353\223\234 \354\240\234\352\263\265.\n- **\353\241\234\354\273\254 \354\212\244\355\206\240\353\246\254\354\247\200 \354\240\200\354\236\245**: \354\236\221\354\204\261\353\220\234 \353\257\270\355\214\205 \352\270\260\353\241\235\354\235\200 \353\270\214\353\235\274\354\232\260\354\240\200\354\235\230 `localStorage`\354\227\220 \354\240\200\354\236\245\353\220\230\354\226\264, \354\203\210\353\241\234\352\263\240\354\271\250 \355\233\204\354\227\220\353\217\204 \353\252\251\353\241\235 \355\231\225\354\235\270 \352\260\200\353\212\245.\n- **\353\202\264\353\263\264\353\202\264\352\270\260**: \354\265\234\354\242\205 \354\210\230\354\240\225\353\220\234 \353\202\264\354\232\251\354\235\204 `.txt` \355\214\214\354\235\274\353\241\234 \353\213\244\354\232\264\353\241\234\353\223\234\355\225\230\353\212\224 \352\270\260\353\212\245.\n\n### 2.4. \353\257\270\355\214\205 \355\236\210\354\212\244\355\206\240\353\246\254 \352\264\200\353\246\254\n- \354\242\214\354\270\241 \354\202\254\354\235\264\353\223\234\353\260\224 \353\230\220\353\212\224 \355\225\230\353\213\250 \353\252\251\353\241\235\354\235\204 \355\206\265\355\225\264 \352\263\274\352\261\260\354\227\220 \354\236\221\354\204\261\353\220\234 \353\257\270\355\214\205 \352\270\260\353\241\235 \353\246\254\354\212\244\355\212\270 \355\231\225\354\235\270.\n- \352\270\260\353\241\235 \354\202\255\354\240\234 \353\260\217 \354\203\201\354\204\270 \353\263\264\352\270\260 \352\270\260\353\212\245.\n\n## 3. \354\230\210\354\231\270 \354\262\230\353\246\254 \353\260\217 UX \352\270\260\355\232\215 (\354\244\221\354\232\224)\n\n### 3.1. \353\270\214\353\235\274\354\232\260\354\240\200 \355\230\270\355\231\230\354\204\261 \354\262\264\355\201\254\n- \354\204\234\353\271\204\354\212\244 \354\240\221\354\206\215 \354\213\234 Chrome \353\270\214\353\235\274\354\232\260\354\240\200 \354\227\254\353\266\200\353\245\274 \355\231\225\354\235\270\355\225\230\352\263\240, `window.SpeechRecognition` \354\247\200\354\233\220 \354\227\254\353\266\200\353\245\274 \354\262\264\355\201\254\355\225\230\354\227\254 \353\257\270\354\247\200\354\233\220 \353\270\214\353\235\274\354\232\260\354\240\200 \354\213\234 \354\225\210\353\202\264 \353\251\224\354\213\234\354\247\200 \354\266\234\353\240\245.\n\n### 3.2. \353\201\212\352\271\200 \353\260\251\354\247\200 \353\241\234\354\247\201 (Keep-alive)\n- `onend` \354\235\264\353\262\244\355\212\270 \353\260\234\354\203\235 \354\213\234, \354\202\254\354\232\251\354\236\220\352\260\200 \354\210\230\353\217\231\354\234\274\353\241\234 \'\354\242\205\353\243\214\' \353\262\204\355\212\274\354\235\204 \353\210\204\353\245\264\354\247\200 \354\225\212\354\225\230\353\213\244\353\251\264 \354\246\211\354\213\234 \354\235\270\354\213\235\354\235\204 \354\236\254\354\213\234\354\236\221\355\225\230\354\227\254 \354\236\245\354\213\234\352\260\204 \353\257\270\355\214\205\354\227\220 \353\214\200\354\235\221.\n\n### 3.3. \353\260\261\352\267\270\353\235\274\354\232\264\353\223\234 \354\236\221\353\217\231 \354\234\240\354\235\230\354\202\254\355\225\255 \354\225\210\353\202\264\n- Web Speech API\353\212\224 \355\203\255\354\235\264 \353\271\204\355\231\234\354\204\261\355\231\224\353\220\230\352\261\260\353\202\230 \354\213\234\354\212\244\355\205\234 \354\240\210\354\240\204 \353\252\250\353\223\234 \354\213\234 \354\244\221\353\213\250\353\220\240 \354\210\230 \354\236\210\354\235\214\354\235\204 \354\202\254\354\232\251\354\236\220\354\227\220\352\262\214 \354\225\214\353\246\254\353\212\224 UI \353\254\270\352\265\254 \355\217\254\355\225\250.\n\n### 3.4. \353\247\210\354\235\264\355\201\254 \352\266\214\355\225\234 \354\232\224\354\262\255\n- \'\352\270\260\353\241\235 \354\213\234\354\236\221\' \353\262\204\355\212\274 \355\201\264\353\246\255 \354\213\234 \353\247\210\354\235\264\355\201\254 \354\202\254\354\232\251 \352\266\214\355\225\234\354\235\264 \352\261\260\353\266\200\353\220\234 \352\262\275\354\232\260, \352\266\214\355\225\234 \354\204\244\354\240\225 \353\260\251\353\262\225 \354\225\210\353\202\264 \353\254\270\352\265\254 \353\205\270\354\266\234.\n\n## 4. UI/UX \353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234\353\235\274\354\235\270 (React/Tailwind)\n- **\354\240\204\354\262\264 \355\206\244\354\225\244\353\247\244\353\204\210**: \354\235\264\353\236\234\353\223\234 \352\267\270\353\243\271\354\235\230 \354\240\225\354\262\264\354\204\261\354\235\204 \353\260\230\354\230\201\355\225\234 \352\271\224\353\201\224\355\225\230\352\263\240 \354\213\240\353\242\260\352\260\220 \354\236\210\353\212\224 \355\231\224\354\235\264\355\212\270/\353\204\244\354\235\264\353\271\204/\352\267\270\353\240\210\354\235\264 \355\206\244.\n- **\353\240\210\354\235\264\354\225\204\354\233\203**: \n    - \354\242\214\354\270\241: \352\263\274\352\261\260 \353\257\270\355\214\205 \352\270\260\353\241\235 \353\252\251\353\241\235 (History)\n    - \354\232\260\354\270\241 \353\251\224\354\235\270: \353\257\270\355\214\205 \354\240\225\353\263\264 \354\236\205\353\240\245 \355\217\274 \353\260\217 \354\213\244\354\213\234\352\260\204 STT \355\205\215\354\212\244\355\212\270 \353\267\260\354\226\264\n- **\354\213\234\352\260\201\354\240\201 \354\232\224\354\206\214**:\n    - \353\205\271\354\235\214 \354\244\221\354\235\274 \353\225\214 \'Red Dot\' \354\225\240\353\213\210\353\251\224\354\235\264\354\205\230\354\235\204 \353\263\264\354\227\254\354\243\274\354\226\264 \354\203\201\355\203\234 \355\221\234\354\213\234.\n    - \355\205\215\354\212\244\355\212\270\352\260\200 \353\263\200\355\231\230\353\220\240 \353\225\214 \354\236\220\354\227\260\354\212\244\353\237\275\352\262\214 \355\225\230\353\213\250\354\234\274\353\241\234 \354\212\244\355\201\254\353\241\244\353\220\230\353\212\224 \352\270\260\353\212\245.\n\n## 5. \354\203\201\354\204\270 \352\260\234\353\260\234 \354\232\224\354\262\255 (AI Studio \355\224\204\353\241\254\355\224\204\355\212\270 \353\263\264\352\260\225)\n1. `window.webkitSpeechRecognition`\354\235\204 \354\202\254\354\232\251\355\225\230\354\227\254 Chrome \355\230\270\355\231\230\354\204\261\354\235\204 \355\231\225\353\263\264\355\225\264 \354\244\230.\n2. `interimResults: true`, `continuous: true` \354\204\244\354\240\225\354\235\204 \352\270\260\353\263\270\354\234\274\353\241\234 \355\225\264 \354\244\230.\n3. \353\215\260\354\235\264\355\204\260\353\212\224 `[{id, title, date, content}]` \355\230\225\355\203\234\354\235\230 \352\260\235\354\262\264 \353\260\260\354\227\264\353\241\234 \353\241\234\354\273\254\354\212\244\355\206\240\353\246\254\354\247\200\354\227\220 \352\264\200\353\246\254\355\225\264 \354\244\230.\n4. \353\252\250\353\223\240 \354\275\224\353\223\234\353\212\224 \352\260\200\353\217\205\354\204\261\354\235\204 \354\234\204\355\225\264 \352\270\260\353\212\245\353\263\204\353\241\234 \354\273\264\355\217\254\353\204\214\355\212\270\353\245\274 \353\266\204\353\246\254(Header, Sidebar, Editor, RecordControl \353\223\261)\355\225\264\354\204\234 \354\236\221\354\204\261\355\225\264 \354\244\230."
    items {
      text: "[Situation] \353\202\230\353\212\224 \353\214\200\353\252\250\354\202\260 \355\230\270\355\205\224\354\202\254\354\227\205\353\266\200\354\235\230 IT \354\204\234\353\271\204\354\212\244 \352\270\260\355\232\215 \353\213\264\353\213\271\354\236\220(PM)\354\225\274.\n[Task] Web Speech API\353\245\274 \355\231\234\354\232\251\355\225\230\354\227\254 \353\257\270\355\214\205 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270\353\241\234 \353\263\200\355\231\230(STT)\355\225\230\352\263\240 \354\240\200\354\236\245\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\202\254\353\202\264 \354\233\271 \354\204\234\353\271\204\354\212\244\353\245\274 \352\265\254\354\266\225\355\225\230\353\240\244\352\263\240 \355\225\264. \354\235\264 \354\204\234\353\271\204\354\212\244\353\245\274 AI Studio\353\245\274 \355\206\265\355\225\234 \'\353\260\224\354\235\264\353\270\214 \354\275\224\353\224\251\'\354\234\274\353\241\234 \352\260\234\353\260\234\355\225\230\352\270\260 \354\234\204\355\225\264, \354\231\204\353\262\275\355\225\234 \355\230\225\355\203\234\354\235\230 PRD(\354\240\234\355\222\210 \354\232\224\352\265\254\354\202\254\355\225\255 \354\240\225\354\235\230\354\204\234)\353\245\274 \354\240\234\354\236\221\355\225\264 \354\244\230.\n[Intent] \354\235\264 \355\224\204\353\241\234\354\240\235\355\212\270\353\245\274 \354\247\204\355\226\211\355\225\230\353\212\224 \354\235\264\354\234\240\353\212\224 \353\266\200\354\204\234 \353\202\264 \354\236\246\354\235\200 \353\257\270\355\214\205 \353\202\264\354\232\251\354\235\204 \353\213\250\354\210\234\355\236\210 \353\205\271\354\235\214\355\225\230\353\212\224 \352\262\203\354\235\204 \353\204\230\354\226\264, \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270 \353\215\260\354\235\264\355\204\260\355\231\224\355\225\230\354\227\254 \355\232\214\354\235\230\353\241\235 \354\236\221\354\204\261 \354\213\234\352\260\204\354\235\204 \353\213\250\354\266\225\355\225\230\352\263\240 \355\225\265\354\213\254 \355\232\214\354\235\230 \353\215\260\354\235\264\355\204\260\353\245\274 \354\236\220\354\202\260\355\231\224\355\225\230\354\227\254 \354\227\205\353\254\264 \355\232\250\354\234\250\354\235\204 \353\206\222\354\235\264\352\270\260 \354\234\204\355\225\250\354\235\264\354\225\274.\n\n[Concerns] \n- AI Studio\354\227\220\354\204\234 \354\202\254\354\232\251\355\225\230\353\212\224 React \352\270\260\354\210\240\354\227\220 \353\247\236\352\262\214 \353\247\214\353\223\244\354\226\264\354\240\270\354\225\274 \355\225\251\353\213\210\353\213\244.\n- Web Speech API\354\235\230 \355\212\271\354\204\261(\353\270\214\353\235\274\354\232\260\354\240\200 \355\230\270\355\231\230\354\204\261, \353\260\261\352\267\270\353\235\274\354\232\264\353\223\234 \354\236\221\353\217\231 \355\225\234\352\263\204 \353\223\261)\354\235\204 \352\263\240\353\240\244\355\225\234 \354\230\210\354\231\270 \354\262\230\353\246\254 \353\260\217 UX \352\270\260\355\232\215\354\235\264 \355\217\254\355\225\250\353\220\230\354\227\210\354\234\274\353\251\264 \354\242\213\352\262\240\354\226\264.\n- \354\265\234\354\242\205\354\240\201\354\234\274\353\241\234 \354\236\221\354\204\261\355\225\264 \354\244\204 PRD\353\212\224 \353\202\264\352\260\200 \355\225\234 \353\262\210\354\227\220 \353\263\265\354\202\254\355\225\264\354\204\234 AI Studio\354\227\220 \353\266\231\354\227\254\353\204\243\354\235\204 \354\210\230 \354\236\210\353\217\204\353\241\235 \353\247\210\355\201\254\353\213\244\354\232\264 \355\230\225\354\213\235\354\235\230 \354\275\224\353\223\234 \353\270\224\353\241\235\354\234\274\353\241\234 \352\260\220\354\213\270\354\204\234 \354\266\234\353\240\245\355\225\264 \354\244\230.\n[Calibration] \353\202\264 \354\235\230\353\217\204\353\245\274 \354\240\225\355\231\225\355\236\210 \355\214\214\354\225\205\355\225\230\354\227\254 \354\265\234\354\240\201\354\235\230 PRD\353\245\274 \354\236\221\354\204\261\355\225\230\352\270\260 \354\234\204\355\225\264, \353\263\270\352\262\251\354\240\201\354\235\270 \353\213\265\353\263\200(PRD \354\236\221\354\204\261)\354\235\204 \354\213\234\354\236\221\355\225\230\352\270\260 \354\240\204\354\227\220 \353\202\230\354\227\220\352\262\214 \355\225\204\354\232\224\355\225\234 \354\240\225\353\263\264\353\245\274 3\352\260\200\354\247\200 \354\235\264\354\203\201 \353\213\250\352\263\204\354\240\201\354\234\274\353\241\234 \354\247\210\353\254\270\355\225\264 \354\244\230.# [PRD] \354\213\244\354\213\234\352\260\204 \353\257\270\355\214\205 \354\235\214\354\204\261 \352\270\260\353\241\235 \353\260\217 \352\264\200\353\246\254 \354\204\234\353\271\204\354\212\244 (Chrome \354\240\204\354\232\251)\n\n## 1. \355\224\204\353\241\234\354\240\235\355\212\270 \352\260\234\354\232\224\n- **\355\224\204\353\241\234\354\240\235\355\212\270 \353\252\205**: E-Land Hotel Meeting Recorder (\352\260\200\354\271\255)\n- **\353\252\251\354\240\201**: \353\257\270\355\214\205 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\205\215\354\212\244\355\212\270\353\241\234 \353\263\200\355\231\230(STT)\355\225\230\354\227\254 \355\232\214\354\235\230\353\241\235 \354\236\221\354\204\261 \354\213\234\352\260\204\354\235\204 \353\213\250\354\266\225\355\225\230\352\263\240, \354\202\254\353\202\264 \355\232\214\354\235\230 \353\215\260\354\235\264\355\204\260\353\245\274 \354\236\220\354\202\260\355\231\224\355\225\250.\n- **\354\243\274\354\232\224 \355\203\200\352\262\237**: \354\235\264\353\236\234\353\223\234 \355\230\270\355\205\224\354\202\254\354\227\205\353\266\200 \354\236\204\354\247\201\354\233\220 (Chrome \353\270\214\353\235\274\354\232\260\354\240\200 \354\202\254\354\232\251\354\236\220)\n- **\352\270\260\354\210\240 \354\212\244\355\203\235**: React (Vite), Tailwind CSS, Lucide React (Icons), Web Speech API\n\n## 2. \355\225\265\354\213\254 \352\270\260\353\212\245 \354\232\224\352\265\254\354\202\254\355\225\255\n\n### 2.1. \353\257\270\355\214\205 \353\251\224\355\203\200\353\215\260\354\235\264\355\204\260 \354\236\205\353\240\245 (\354\236\205\353\240\245 \355\217\274)\n- \353\257\270\355\214\205 \354\213\234\354\236\221 \354\240\204, \353\213\244\354\235\214\352\263\274 \352\260\231\354\235\200 \354\240\225\353\263\264\353\245\274 \354\236\205\353\240\245\355\225\240 \354\210\230 \354\236\210\353\212\224 \355\217\274\354\235\204 \354\240\234\352\263\265\355\225\250.\n    - \353\257\270\355\214\205 \354\240\234\353\252\251 (\355\225\204\354\210\230)\n    - \353\266\200\354\204\234\353\252\205 / \354\260\270\354\204\235\354\236\220\n    - \353\202\240\354\247\234 (\352\270\260\353\263\270\352\260\222: \354\230\244\353\212\230)\n\n### 2.2. \354\213\244\354\213\234\352\260\204 STT (Web Speech API \355\231\234\354\232\251)\n- **\354\213\244\354\213\234\352\260\204 \355\205\215\354\212\244\355\212\270 \353\263\200\355\231\230**: \353\247\210\354\235\264\355\201\254 \352\266\214\355\225\234 \354\212\271\354\235\270 \355\233\204, \354\202\254\354\232\251\354\236\220\354\235\230 \354\235\214\354\204\261\354\235\204 \354\213\244\354\213\234\352\260\204\354\234\274\353\241\234 \355\231\224\353\251\264\354\227\220 \354\266\234\353\240\245\355\225\250.\n- **\355\231\225\354\240\225/\353\271\204\355\231\225\354\240\225 \355\205\215\354\212\244\355\212\270 \352\265\254\353\266\204**: \353\263\200\355\231\230 \354\244\221\354\235\270 \353\254\270\354\236\245(Interim)\352\263\274 \353\263\200\355\231\230\354\235\264 \354\231\204\353\243\214\353\220\234 \353\254\270\354\236\245\354\235\204 \354\213\234\352\260\201\354\240\201\354\234\274\353\241\234 \352\265\254\353\266\204\355\225\230\354\227\254 \354\202\254\354\232\251\354\236\220 \352\262\275\355\227\230 \355\226\245\354\203\201.\n- **\354\227\260\354\206\215 \354\235\270\354\213\235 \354\262\230\353\246\254**: Web Speech API\354\235\230 \355\212\271\354\247\225\354\235\270 \'\353\254\264\354\235\214 \354\213\234 \354\236\220\353\217\231 \354\242\205\353\243\214\'\353\245\274 \353\260\251\354\247\200\355\225\230\352\270\260 \354\234\204\355\225\264, \354\235\270\354\213\235\354\235\264 \353\201\212\352\270\270 \352\262\275\354\232\260 \354\236\220\353\217\231\354\234\274\353\241\234 \353\213\244\354\213\234 \354\213\234\354\236\221\355\225\230\353\212\224 \353\241\234\354\247\201 \355\217\254\355\225\250.\n\n### 2.3. \352\270\260\353\241\235 \355\216\270\354\247\221 \353\260\217 \354\240\200\354\236\245\n- **\354\210\230\354\240\225 \353\252\250\353\223\234**: \352\270\260\353\241\235\354\235\264 \354\231\204\353\243\214\353\220\234 \355\233\204(Stop), \354\203\235\354\204\261\353\220\234 \355\205\215\354\212\244\355\212\270 \354\240\204\354\262\264\353\245\274 \354\236\220\354\234\240\353\241\255\352\262\214 \354\210\230\354\240\225\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\227\220\353\224\224\355\204\260 \353\252\250\353\223\234 \354\240\234\352\263\265.\n- **\353\241\234\354\273\254 \354\212\244\355\206\240\353\246\254\354\247\200 \354\240\200\354\236\245**: \354\236\221\354\204\261\353\220\234 \353\257\270\355\214\205 \352\270\260\353\241\235\354\235\200 \353\270\214\353\235\274\354\232\260\354\240\200\354\235\230 `localStorage`\354\227\220 \354\240\200\354\236\245\353\220\230\354\226\264, \354\203\210\353\241\234\352\263\240\354\271\250 \355\233\204\354\227\220\353\217\204 \353\252\251\353\241\235 \355\231\225\354\235\270 \352\260\200\353\212\245.\n- **\353\202\264\353\263\264\353\202\264\352\270\260**: \354\265\234\354\242\205 \354\210\230\354\240\225\353\220\234 \353\202\264\354\232\251\354\235\204 `.txt` \355\214\214\354\235\274\353\241\234 \353\213\244\354\232\264\353\241\234\353\223\234\355\225\230\353\212\224 \352\270\260\353\212\245.\n\n### 2.4. \353\257\270\355\214\205 \355\236\210\354\212\244\355\206\240\353\246\254 \352\264\200\353\246\254\n- \354\242\214\354\270\241 \354\202\254\354\235\264\353\223\234\353\260\224 \353\230\220\353\212\224 \355\225\230\353\213\250 \353\252\251\353\241\235\354\235\204 \355\206\265\355\225\264 \352\263\274\352\261\260\354\227\220 \354\236\221\354\204\261\353\220\234 \353\257\270\355\214\205 \352\270\260\353\241\235 \353\246\254\354\212\244\355\212\270 \355\231\225\354\235\270.\n- \352\270\260\353\241\235 \354\202\255\354\240\234 \353\260\217 \354\203\201\354\204\270 \353\263\264\352\270\260 \352\270\260\353\212\245.\n\n## 3. \354\230\210\354\231\270 \354\262\230\353\246\254 \353\260\217 UX \352\270\260\355\232\215 (\354\244\221\354\232\224)\n\n### 3.1. \353\270\214\353\235\274\354\232\260\354\240\200 \355\230\270\355\231\230\354\204\261 \354\262\264\355\201\254\n- \354\204\234\353\271\204\354\212\244 \354\240\221\354\206\215 \354\213\234 Chrome \353\270\214\353\235\274\354\232\260\354\240\200 \354\227\254\353\266\200\353\245\274 \355\231\225\354\235\270\355\225\230\352\263\240, `window.SpeechRecognition` \354\247\200\354\233\220 \354\227\254\353\266\200\353\245\274 \354\262\264\355\201\254\355\225\230\354\227\254 \353\257\270\354\247\200\354\233\220 \353\270\214\353\235\274\354\232\260\354\240\200 \354\213\234 \354\225\210\353\202\264 \353\251\224\354\213\234\354\247\200 \354\266\234\353\240\245.\n\n### 3.2. \353\201\212\352\271\200 \353\260\251\354\247\200 \353\241\234\354\247\201 (Keep-alive)\n- `onend` \354\235\264\353\262\244\355\212\270 \353\260\234\354\203\235 \354\213\234, \354\202\254\354\232\251\354\236\220\352\260\200 \354\210\230\353\217\231\354\234\274\353\241\234 \'\354\242\205\353\243\214\' \353\262\204\355\212\274\354\235\204 \353\210\204\353\245\264\354\247\200 \354\225\212\354\225\230\353\213\244\353\251\264 \354\246\211\354\213\234 \354\235\270\354\213\235\354\235\204 \354\236\254\354\213\234\354\236\221\355\225\230\354\227\254 \354\236\245\354\213\234\352\260\204 \353\257\270\355\214\205\354\227\220 \353\214\200\354\235\221.\n\n### 3.3. \353\260\261\352\267\270\353\235\274\354\232\264\353\223\234 \354\236\221\353\217\231 \354\234\240\354\235\230\354\202\254\355\225\255 \354\225\210\353\202\264\n- Web Speech API\353\212\224 \355\203\255\354\235\264 \353\271\204\355\231\234\354\204\261\355\231\224\353\220\230\352\261\260\353\202\230 \354\213\234\354\212\244\355\205\234 \354\240\210\354\240\204 \353\252\250\353\223\234 \354\213\234 \354\244\221\353\213\250\353\220\240 \354\210\230 \354\236\210\354\235\214\354\235\204 \354\202\254\354\232\251\354\236\220\354\227\220\352\262\214 \354\225\214\353\246\254\353\212\224 UI \353\254\270\352\265\254 \355\217\254\355\225\250.\n\n### 3.4. \353\247\210\354\235\264\355\201\254 \352\266\214\355\225\234 \354\232\224\354\262\255\n- \'\352\270\260\353\241\235 \354\213\234\354\236\221\' \353\262\204\355\212\274 \355\201\264\353\246\255 \354\213\234 \353\247\210\354\235\264\355\201\254 \354\202\254\354\232\251 \352\266\214\355\225\234\354\235\264 \352\261\260\353\266\200\353\220\234 \352\262\275\354\232\260, \352\266\214\355\225\234 \354\204\244\354\240\225 \353\260\251\353\262\225 \354\225\210\353\202\264 \353\254\270\352\265\254 \353\205\270\354\266\234.\n\n## 4. UI/UX \353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234\353\235\274\354\235\270 (React/Tailwind)\n- **\354\240\204\354\262\264 \355\206\244\354\225\244\353\247\244\353\204\210**: \354\235\264\353\236\234\353\223\234 \352\267\270\353\243\271\354\235\230 \354\240\225\354\262\264\354\204\261\354\235\204 \353\260\230\354\230\201\355\225\234 \352\271\224\353\201\224\355\225\230\352\263\240 \354\213\240\353\242\260\352\260\220 \354\236\210\353\212\224 \355\231\224\354\235\264\355\212\270/\353\204\244\354\235\264\353\271\204/\352\267\270\353\240\210\354\235\264 \355\206\244.\n- **\353\240\210\354\235\264\354\225\204\354\233\203**: \n    - \354\242\214\354\270\241: \352\263\274\352\261\260 \353\257\270\355\214\205 \352\270\260\353\241\235 \353\252\251\353\241\235 (History)\n    - \354\232\260\354\270\241 \353\251\224\354\235\270: \353\257\270\355\214\205 \354\240\225\353\263\264 \354\236\205\353\240\245 \355\217\274 \353\260\217 \354\213\244\354\213\234\352\260\204 STT \355\205\215\354\212\244\355\212\270 \353\267\260\354\226\264\n- **\354\213\234\352\260\201\354\240\201 \354\232\224\354\206\214**:\n    - \353\205\271\354\235\214 \354\244\221\354\235\274 \353\225\214 \'Red Dot\' \354\225\240\353\213\210\353\251\224\354\235\264\354\205\230\354\235\204 \353\263\264\354\227\254\354\243\274\354\226\264 \354\203\201\355\203\234 \355\221\234\354\213\234.\n    - \355\205\215\354\212\244\355\212\270\352\260\200 \353\263\200\355\231\230\353\220\240 \353\225\214 \354\236\220\354\227\260\354\212\244\353\237\275\352\262\214 \355\225\230\353\213\250\354\234\274\353\241\234 \354\212\244\355\201\254\353\241\244\353\220\230\353\212\224 \352\270\260\353\212\245.\n\n## 5. \354\203\201\354\204\270 \352\260\234\353\260\234 \354\232\224\354\262\255 (AI Studio \355\224\204\353\241\254\355\224\204\355\212\270 \353\263\264\352\260\225)\n1. `window.webkitSpeechRecognition`\354\235\204 \354\202\254\354\232\251\355\225\230\354\227\254 Chrome \355\230\270\355\231\230\354\204\261\354\235\204 \355\231\225\353\263\264\355\225\264 \354\244\230.\n2. `interimResults: true`, `continuous: true` \354\204\244\354\240\225\354\235\204 \352\270\260\353\263\270\354\234\274\353\241\234 \355\225\264 \354\244\230.\n3. \353\215\260\354\235\264\355\204\260\353\212\224 `[{id, title, date, content}]` \355\230\225\355\203\234\354\235\230 \352\260\235\354\262\264 \353\260\260\354\227\264\353\241\234 \353\241\234\354\273\254\354\212\244\355\206\240\353\246\254\354\247\200\354\227\220 \352\264\200\353\246\254\355\225\264 \354\244\230.\n4. \353\252\250\353\223\240 \354\275\224\353\223\234\353\212\224 \352\260\200\353\217\205\354\204\261\354\235\204 \354\234\204\355\225\264 \352\270\260\353\212\245\353\263\204\353\241\234 \354\273\264\355\217\254\353\204\214\355\212\270\353\245\274 \353\266\204\353\246\254(Header, Sidebar, Editor, RecordControl \353\223\261)\355\225\264\354\204\234 \354\236\221\354\204\261\355\225\264 \354\244\230."
    }
