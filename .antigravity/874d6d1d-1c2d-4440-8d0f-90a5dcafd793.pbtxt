          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  - \355\224\204\353\241\240\355\212\270 \354\213\235\354\235\214\353\243\214(F&B) \353\260\234\354\243\274 \354\235\270\355\224\204\353\235\274\354\231\200 \353\241\234\353\264\207 \354\213\234\354\212\244\355\205\234 \352\260\204 API \354\227\260\353\217\231 \352\267\234\352\262\251\354\235\204 \354\244\200\353\271\204 \354\244\221."
